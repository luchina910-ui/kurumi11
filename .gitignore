```gitignore
# Dependencies
node_modules/

# Logs and temp files
*.log
*.tmp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
*.coverage

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.nox/
*.so

# Build artifacts
dist/
build/
*.egg-info/
.eggs/

# Compression files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# System files
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.mypy_cache/
.hypothesis/

# Java/Maven
target/
.gradle/
*.class
*.jar
*.war
*.ear

# C/C++
*.o
*.obj
*.a
*.so
*.dll
*.exe
*.out

# Go
*.exe
*.test
*.prof
vendor/

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ruby
*.gem
*.rbc
.bundle/
.config/yardoc/
.yardoc/
Gemfile.lock

# Rust
Cargo.lock
target/

# Julia
.julia/

# Zig
zig-cache/
zig-out/

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*.swo

# OS generated files
.DS_Store?
ehthumbs.db
Icon?
Thumbs.db
```